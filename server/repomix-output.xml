<file path="src/models/Blockchain.js">
const fs = require('fs');   
const path = require('path');
const { generateHash } = require('../utils/hashUtils');

const CHAIN_FILE = path.join(__dirname, '../../blockchain_data.json'); // <--- WAS MISSING

class Block {
    constructor(index, timestamp, recordId, dataHash, previousHash = '') {
        this.index = index;
        this.timestamp = timestamp;
        this.recordId = recordId;     // Link to MySQL ID
        this.dataHash = dataHash;     // Hash of the medical data
        this.previousHash = previousHash;
        this.currentHash = this.calculateHash(); // Hash of THIS block
    }

    calculateHash() {
        // We hash the entire block's content to ensure immutability
        return generateHash(
            this.index + 
            this.previousHash + 
            this.timestamp + 
            JSON.stringify(this.dataHash)
        );
    }
}

class Blockchain {
    constructor() {
        // Load chain from file if it exists
        if (fs.existsSync(CHAIN_FILE)) {
            this.chain = JSON.parse(fs.readFileSync(CHAIN_FILE));
        } else {
            this.chain = [this.createGenesisBlock()];
            this.saveChain();
        }
    }

    createGenesisBlock() {
        return new Block(0, new Date().toISOString(), 0, "GENESIS_BLOCK", "0");
    }

    getLatestBlock() {
        return this.chain[this.chain.length - 1];
    }

    addBlock(recordId, dataHash) {
        const previousBlock = this.getLatestBlock();
        const newBlock = new Block(
            this.chain.length,
            new Date().toISOString(),
            recordId,
            dataHash,
            previousBlock.currentHash
        );
        this.chain.push(newBlock);
        this.saveChain();
        console.log(`🔗 [Blockchain] New Block Added: Index ${newBlock.index}`);
    }

    saveChain() {
        fs.writeFileSync(CHAIN_FILE, JSON.stringify(this.chain, null, 2));
    }

    // Find a block by the MySQL Record ID
    getBlockByRecordId(recordId) {
        return this.chain.find(block => block.recordId == recordId);
    }

    // Verify if the entire chain is valid (Optional Integrity Check)
    isChainValid() {
        for (let i = 1; i < this.chain.length; i++) {
            const currentBlock = this.chain[i];
            const previousBlock = this.chain[i - 1];

            if (currentBlock.currentHash !== currentBlock.calculateHash()) return false;
            if (currentBlock.previousHash !== previousBlock.currentHash) return false;
        }
        return true;
    }
}

// Export a SINGLE instance (Singleton Pattern) so state persists in memory
module.exports = new Blockchain();
