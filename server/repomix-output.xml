// server/generate_demo.js
const API_URL = 'http://localhost:3000/api';

async function runDemoGenerator() {
    console.log("🚀 Starting HealthChain Demo Data Generator...");

    // Helper: Register User
    const register = async (username, role) => {
        try {
            await fetch(`${API_URL}/register`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username, password: 'password123', role })
            });
            console.log(`✅ Registered ${role.toUpperCase()}: ${username}`);
        } catch (e) {
            console.log(`⚠️ User ${username} might already exist.`);
        }
    };

    // Helper: Login User
    const login = async (username) => {
        const res = await fetch(`${API_URL}/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password: 'password123' })
        });
        const data = await res.json();
        return data.token;
    };

    // Helper: Add Medical Record
    const addRecord = async (token, payload) => {
        const res = await fetch(`${API_URL}/records`, {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify(payload)
        });
        const data = await res.json();
        
        // NEW: Check if the backend sent an error instead of success
        if (!res.ok || data.error) {
            console.error(`❌ Backend rejected record for patient ${payload.patient_id}:`, data);
            return;
        }

        console.log(`🏥 Added Record for Patient ID ${payload.patient_id} | Hash: ${data.blockchainHash.substring(0,10)}...`);
    };

    try {
        // 1. Register Fake Doctors and Patients
        console.log("\n--- Creating Accounts ---");
        await register('dr_house', 'doctor');
        await register('dr_strange', 'doctor');
        await register('bruce_wayne', 'patient');
        await register('clark_kent', 'patient');
        await register('peter_parker', 'patient');

        // 2. Log in as Dr. House to get a token and the patient list
        console.log("\n--- Fetching Patient List ---");
        const doctorToken = await login('dr_house');
        
        const patientsRes = await fetch(`${API_URL}/patients`, {
            headers: { 'Authorization': `Bearer ${doctorToken}` }
        });
        const patients = await patientsRes.json();
        
        // Helper to find patient ID by their username (which is saved as last_name in our auto-provision)
        const getPatientId = (username) => {
            const p = patients.find(p => p.last_name === username);
            return p ? p.id : 1;
        };

        // 3. Generate Realistic Medical Records
        console.log("\n--- Generating Medical Records & Blockchain Hashes ---");
        
        await addRecord(doctorToken, {
            patient_id: getPatientId('bruce_wayne'),
            subjective: 'Patient complains of chronic back pain and fatigue from night shifts.',
            vitals: { bp: '130/85', hr: '65', temp: '98.2' },
            assessment: 'Muscular Strain',
            plan: 'Rest, Ibuprofen 400mg PRN, physical therapy.'
        });

        await addRecord(doctorToken, {
            patient_id: getPatientId('clark_kent'),
            subjective: 'Routine checkup. Patient feels unusually weak around certain green minerals.',
            vitals: { bp: '120/80', hr: '55', temp: '98.6' },
            assessment: 'Perfect Health (Anomalous weakness noted)',
            plan: 'Avoid radiation. Regular diet.'
        });

        await addRecord(doctorToken, {
            patient_id: getPatientId('peter_parker'),
            subjective: 'Patient reports dizziness, blurred vision, and a strange rash resembling a bug bite.',
            vitals: { bp: '140/90', hr: '88', temp: '100.1' },
            assessment: 'Acute Viral Infection / Insect Bite',
            plan: 'Blood test ordered. Apply topical steroid cream.'
        });

        await addRecord(doctorToken, {
            patient_id: getPatientId('bruce_wayne'),
            subjective: 'Follow up for back pain. Patient states it is worsening.',
            vitals: { bp: '135/88', hr: '70', temp: '98.4' },
            assessment: 'Severe Muscular Strain',
            plan: 'MRI scheduled. Prescribed muscle relaxants.'
        });

        console.log("\n🎉 DEMO DATA GENERATION COMPLETE! 🎉");
        console.log("You can now log in with username: 'dr_house' and password: 'password123'");

    } catch (err) {
        console.error("Error generating data:", err);
    }
}

runDemoGenerator();
