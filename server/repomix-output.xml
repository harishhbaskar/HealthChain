<file path="src/models/Records.js">
const db = require('../config/db');

// Promise-based pool for async/await transaction handling
const promiseDb = db.promise();

const Record = {

    // =========================================================
    // Transactional insert across visits, vitals, diagnoses,
    // and prescriptions. Rolls back on ANY failure.
    // =========================================================
    createFullVisit: async (visitData, vitalsData, diagnosisData, prescriptionData) => {
        const conn = await promiseDb; // mysql2 connection.promise()

        await conn.beginTransaction();

        try {
            // 1. Insert visit (record_hash is set to NULL initially, updated after hashing)
            const [visitResult] = await conn.execute(
                `INSERT INTO visits (patient_id, doctor_id, chief_complaint, visit_date)
                 VALUES (?, ?, ?, NOW())`,
                [visitData.patient_id, visitData.doctor_id, visitData.chief_complaint]
            );
            const visitId = visitResult.insertId;

            // 2. Insert vitals
            await conn.execute(
                `INSERT INTO vitals (visit_id, blood_pressure, heart_rate, temperature)
                 VALUES (?, ?, ?, ?)`,
                [visitId, vitalsData.bp, vitalsData.hr, vitalsData.temp]
            );

            // 3. Insert diagnosis
            await conn.execute(
                `INSERT INTO diagnoses (visit_id, condition_name) VALUES (?, ?)`,
                [visitId, diagnosisData.condition_name]
            );

            // 4. Insert prescription
            await conn.execute(
                `INSERT INTO prescriptions (visit_id, medication_name, instructions)
                 VALUES (?, ?, ?)`,
                [visitId, prescriptionData.medication_name, prescriptionData.instructions]
            );

            await conn.commit();
            return visitId;
        } catch (err) {
            await conn.rollback();
            throw err;
        }
    },

    // =========================================================
    // Update the record_hash on visits after hashing
    // =========================================================
    updateVisitHash: async (visitId, recordHash) => {
        const conn = await promiseDb;
        await conn.execute(
            `UPDATE visits SET record_hash = ? WHERE id = ?`,
            [recordHash, visitId]
        );
    },

    // =========================================================
    // JOIN query: single visit with related vitals, diagnosis,
    // and prescription data
    // =========================================================
    getFullVisitById: async (visitId) => {
        const conn = await promiseDb;
        const [rows] = await conn.execute(
            `SELECT
                v.id            AS visit_id,
                v.patient_id,
                v.doctor_id,
                v.chief_complaint,
                v.visit_date,
                v.record_hash,
                vt.blood_pressure,
                vt.heart_rate,
                vt.temperature,
                d.condition_name,
                p.medication_name,
                p.instructions
             FROM visits v
             LEFT JOIN vitals        vt ON vt.visit_id = v.id
             LEFT JOIN diagnoses     d  ON d.visit_id  = v.id
             LEFT JOIN prescriptions p  ON p.visit_id  = v.id
             WHERE v.id = ?`,
            [visitId]
        );
        return rows.length ? rows[0] : null;
    },

    // =========================================================
    // All visits for a given patient (summary + joined detail)
    // =========================================================
    getVisitsByPatient: async (patientId) => {
        const conn = await promiseDb;
        const [rows] = await conn.execute(
            `SELECT
                v.id            AS visit_id,
                v.patient_id,
                v.doctor_id,
                v.chief_complaint,
                v.visit_date,
                v.record_hash,
                vt.blood_pressure,
                vt.heart_rate,
                vt.temperature,
                d.condition_name,
                p.medication_name,
                p.instructions
             FROM visits v
             LEFT JOIN vitals        vt ON vt.visit_id = v.id
             LEFT JOIN diagnoses     d  ON d.visit_id  = v.id
             LEFT JOIN prescriptions p  ON p.visit_id  = v.id
             WHERE v.patient_id = ?
             ORDER BY v.visit_date DESC`,
            [patientId]
        );
        return rows;
    }
};

module.exports = Record;
</file>

