# ── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT Auth (REQUIRED in production) ───────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex

# ── Database ─────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
DB_NAME=healthchain_db

# TiDB Serverless / PlanetScale / hosted MySQL with TLS:
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_SSL_CA_PATH=/absolute/path/to/ca.pem

# Local dev (plain MySQL):
DB_SSL=false

# ── Field-level encryption ───────────────────────────────────────────
# 64-char hex (32 bytes). DO NOT change after encrypting rows.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=replace_with_64_char_hex

# ── CORS ─────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── Local HTTPS (optional, dev only) ─────────────────────────────────
# LOCAL_HTTPS=true
# HTTPS_PORT=3443
# HTTPS_KEY_PATH=/absolute/path/to/localhost-key.pem
# HTTPS_CERT_PATH=/absolute/path/to/localhost.pem
# REDIRECT_HTTP_TO_HTTPS=true
