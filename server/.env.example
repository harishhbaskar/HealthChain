# Core API
PORT=3000

# Local HTTPS mode
LOCAL_HTTPS=true
HTTPS_PORT=3443
HTTPS_KEY_PATH=/absolute/path/to/localhost-key.pem
HTTPS_CERT_PATH=/absolute/path/to/localhost.pem
REDIRECT_HTTP_TO_HTTPS=true

# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root123
DB_NAME=healthchain_db

# Optional MySQL TLS
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA_PATH=/absolute/path/to/ca.pem
# DB_SSL_CERT_PATH=/absolute/path/to/client-cert.pem
# DB_SSL_KEY_PATH=/absolute/path/to/client-key.pem

# Field encryption (safe first pass)
# Use a long random secret; do not rotate casually in dev once encrypted rows exist.
FIELD_ENCRYPTION_KEY=replace_with_long_random_secret
